{
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/.pnpm/**": true,
    "**/.pnpm-store/**": true,
    "**/.next/**": true,
    "**/out/**": true,
    "**/coverage/**": true,
    "**/.turbo/**": true,
    "**/ios/Pods/**": true,
    "**/android/.gradle/**": true,
    "**/build/**": true,
    "**/dist/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.pnpm": true,
    "**/.pnpm-store": true,
    "**/.next": true,
    "**/out": true,
    "**/coverage": true,
    "**/.turbo": true,
    "**/bower_components": true,
    "**/ios/Pods": true,
    "**/android/.gradle": true,
    "**/*.code-search": true
  },
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/node_modules": false
  }
}
